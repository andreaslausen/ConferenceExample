{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.Core/Stryker.Core/schema.json",
  "stryker-config": {
    "thresholds": {
      "high": 100,
      "low": 100,
      "break": 100
    },
    "reporters": [
      "progress",
      "html",
      "cleartext"
    ],
    "verbosity": "info",
    "concurrency": 4,
    "ignore-mutations": [
      "string"
    ]
  }
}